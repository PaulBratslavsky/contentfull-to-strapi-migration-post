# OPTIONAL. If you ran `contentful login` and `contentful space use`, you can skip this
# file entirely — the seed reads the CLI's stored credentials (~/.contentfulrc.json).
#
# Set these only if you prefer explicit credentials (e.g. in CI). When present, they
# override the CLI config.

# Your Contentful space + environment
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT_ID=master

# A Content Management API (CMA) token — NOT a Content Delivery token.
# Contentful web app: Settings -> API keys -> Content management tokens ->
# Generate personal token. It has read/write access, so keep it secret.
CONTENTFUL_MANAGEMENT_TOKEN=
