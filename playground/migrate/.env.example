# Where your Strapi v5 instance is running
STRAPI_URL=http://localhost:1337

# A Strapi *Full access* (or custom write) API token.
# Create it in the admin panel: Settings -> API Tokens -> Create new API Token.
# For an automated run you can mint one with:
#   cd ../strapi-server && node scripts/create-api-token.mjs
STRAPI_API_TOKEN=

# The locale code used in your Contentful export (the value fields are nested under).
# `contentful export` nests every field value under its locale, e.g. { "title": { "en-US": "..." } }.
CONTENTFUL_LOCALE=en-US
